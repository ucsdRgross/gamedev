#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Class/script is a Resource subclass."
msgstr "Klasa/skrypt jest podklasą Resource."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid ""
"Invalid class/script. Expected a Resource subclass (built-in, class_name, or "
"[u]quoted[/u] script path)."
msgstr ""
"Nieprawidłowa klasa/skrypt. Oczekiwana podklasa Resource (wbudowana, "
"class_name lub [u]cytowana[/u] ścieżka skryptu)."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "No class filter, all Resource files will be accepted to the registry."
msgstr ""
"Brak filtra klas, wszystkie pliki Resource zostaną przyjęte do rejestru."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Scan directory valid. Will watch for new Resources…"
msgstr "Katalog prawidłowy. Nowe zasoby będą wykrywane automatycznie…"

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Scan directory is set to the project root ([code]res://[/code]). This will scan the entire project on every file save, which may cause significant editor lag."
msgstr "Katalog skanowania jest ustawiony na katalog główny projektu ([code]res://[/code]). Spowoduje to skanowanie całego projektu przy każdym zapisie pliku, co może znacznie spowolnić edytor."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Scan directory invalid. Pick an existing directory."
msgstr "Nieprawidłowy katalog. Wybierz istniejący katalog."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "No scan directory, resources auto-discovery is disabled."
msgstr "Brak katalogu, automatyczne wykrywanie jest wyłączone."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid ""
"File extension restrictions are optional. Separate multiple extensions with "
"commas."
msgstr ""
"Ograniczenia rozszerzeń plików są opcjonalne. Wiele rozszerzeń oddziel "
"przecinkami."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid ""
"File extension filter active. Scan will be limited to matching extensions."
msgstr ""
"Filtr rozszerzeń aktywny. Skanowanie będzie ograniczone do pasujących "
"rozszerzeń."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Empty file extension detected. Remove extra commas."
msgstr "Wykryto puste rozszerzenie pliku. Usuń zbędne przecinki."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Invalid file extension detected. Remove disallowed characters."
msgstr "Wykryto nieprawidłowe rozszerzenie pliku. Usuń niedozwolone znaki."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Include filter active. Only matching paths will be scanned."
msgstr "Filtr dołączania aktywny. Skanowane będą tylko pasujące ścieżki."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Invalid include regex pattern."
msgstr "Nieprawidłowe wyrażenie regularne dołączania."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Exclude filter active. Matching paths will be skipped."
msgstr "Filtr wykluczania aktywny. Pasujące ścieżki zostaną pominięte."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Invalid exclude regex pattern."
msgstr "Nieprawidłowe wyrażenie regularne wykluczania."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid ""
"Indexed properties are optional. Separate multiple properties with commas."
msgstr ""
"Indeksowane właściwości są opcjonalne. Wiele właściwości oddziel przecinkami."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "All properties found on the specified resource class."
msgstr "Wszystkie właściwości klasy zasobu zostały znalezione."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Empty property name detected. Remove extra commas."
msgstr "Wykryto pustą nazwę właściwości. Usuń zbędne przecinki."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Property '{prop}' is declared on multiple classes with different types."
msgstr ""
"Właściwość '{prop}' jest zadeklarowana w wielu klasach z różnymi typami."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Property '{prop}' may not exist on class {class_n}."
msgstr "Właściwość '{prop}' może nie istnieć w klasie {class_n}."

