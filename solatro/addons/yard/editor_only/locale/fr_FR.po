#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Class/script is a Resource subclass."
msgstr "La classe/le script est une sous-classe de Resource."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid ""
"Invalid class/script. Expected a Resource subclass (built-in, class_name, or "
"[u]quoted[/u] script path)."
msgstr ""
"Classe/script invalide. Une sous-classe de Resource est attendue (intégrée, "
"class_name, ou chemin de script [u]entre guillemets[/u])."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "No class filter, all Resource files will be accepted to the registry."
msgstr ""
"Aucun filtre de classe, tous les fichiers Resource seront acceptés dans le "
"registre."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Scan directory valid. Will watch for new Resources…"
msgstr ""
"Répertoire valide. Les nouvelles ressources seront détectées automatiquement…"

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Scan directory is set to the project root ([code]res://[/code]). This will scan the entire project on every file save, which may cause significant editor lag."
msgstr "Le répertoire à analyser est défini sur la racine du projet ([code]res://[/code]). Cela analysera l'ensemble du projet à chaque sauvegarde, ce qui peut entraîner des ralentissements significatifs dans l'éditeur."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Scan directory invalid. Pick an existing directory."
msgstr "Répertoire invalide. Choisissez un répertoire existant."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "No scan directory, resources auto-discovery is disabled."
msgstr "Aucun répertoire défini, la détection automatique est désactivée."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid ""
"File extension restrictions are optional. Separate multiple extensions with "
"commas."
msgstr ""
"Les extensions de fichier sont optionnelles. Séparez plusieurs extensions "
"avec des virgules."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid ""
"File extension filter active. Scan will be limited to matching extensions."
msgstr ""
"Filtre d'extension actif. L'analyse sera limitée aux extensions "
"correspondantes."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Empty file extension detected. Remove extra commas."
msgstr "Extension de fichier vide détectée. Supprimez les virgules superflues."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Invalid file extension detected. Remove disallowed characters."
msgstr "Extension de fichier invalide. Supprimez les caractères non autorisés."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Include filter active. Only matching paths will be scanned."
msgstr ""
"Filtre d'inclusion actif. Seuls les chemins correspondants seront analysés."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Invalid include regex pattern."
msgstr "Expression régulière d'inclusion invalide."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Exclude filter active. Matching paths will be skipped."
msgstr "Filtre d'exclusion actif. Les chemins correspondants seront ignorés."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Invalid exclude regex pattern."
msgstr "Expression régulière d'exclusion invalide."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
