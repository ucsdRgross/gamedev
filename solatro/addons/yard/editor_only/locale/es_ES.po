#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Class/script is a Resource subclass."
msgstr "La clase/script es una subclase de Resource."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid ""
"Invalid class/script. Expected a Resource subclass (built-in, class_name, or "
"[u]quoted[/u] script path)."
msgstr ""
"Clase/script no válido. Se esperaba una subclase de Resource (integrada, "
"class_name, o ruta de script [u]entre comillas[/u])."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "No class filter, all Resource files will be accepted to the registry."
msgstr ""
"Sin filtro de clase, todos los archivos Resource serán aceptados en el "
"registro."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Scan directory valid. Will watch for new Resources…"
msgstr "Directorio válido. Los nuevos recursos se detectarán automáticamente…"

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Scan directory is set to the project root ([code]res://[/code]). This will scan the entire project on every file save, which may cause significant editor lag."
msgstr "El directorio de análisis está configurado como la raíz del proyecto ([code]res://[/code]). Esto analizará todo el proyecto en cada guardado de archivo, lo que puede causar una ralentización significativa del editor."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Scan directory invalid. Pick an existing directory."
msgstr "Directorio no válido. Elija un directorio existente."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "No scan directory, resources auto-discovery is disabled."
msgstr "Sin directorio definido, la detección automática está desactivada."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid ""
"File extension restrictions are optional. Separate multiple extensions with "
"commas."
msgstr ""
"Las restricciones de extensión de archivo son opcionales. Separa varias "
"extensiones con comas."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid ""
"File extension filter active. Scan will be limited to matching extensions."
msgstr ""
"Filtro de extensiones activo. El análisis se limitará a las extensiones "
"coincidentes."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Empty file extension detected. Remove extra commas."
msgstr "Extensión de archivo vacía detectada. Elimina las comas sobrantes."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Invalid file extension detected. Remove disallowed characters."
msgstr ""
"Extensión de archivo no válida detectada. Elimina los caracteres no "
"permitidos."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Include filter active. Only matching paths will be scanned."
msgstr ""
"Filtro de inclusión activo. Solo se analizarán las rutas que coincidan."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Invalid include regex pattern."
msgstr "Expresión regular de inclusión no válida."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Exclude filter active. Matching paths will be skipped."
msgstr "Filtro de exclusión activo. Las rutas que coincidan serán omitidas."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Invalid exclude regex pattern."
msgstr "Expresión regular de exclusión no válida."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid ""
"Indexed properties are optional. Separate multiple properties with commas."
