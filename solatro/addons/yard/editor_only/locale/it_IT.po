#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Class/script is a Resource subclass."
msgstr "La classe/lo script è una sottoclasse di Resource."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid ""
"Invalid class/script. Expected a Resource subclass (built-in, class_name, or "
"[u]quoted[/u] script path)."
msgstr ""
"Classe/script non valido. È attesa una sottoclasse di Resource (integrata, "
"class_name, o percorso script [u]tra virgolette[/u])."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "No class filter, all Resource files will be accepted to the registry."
msgstr ""
"Nessun filtro di classe, tutti i file Resource verranno accettati nel "
"registro."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Scan directory valid. Will watch for new Resources…"
msgstr "Directory valida. Le nuove risorse verranno rilevate automaticamente…"

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Scan directory is set to the project root ([code]res://[/code]). This will scan the entire project on every file save, which may cause significant editor lag."
msgstr "La directory di scansione è impostata sulla radice del progetto ([code]res://[/code]). Questo analizzerà l'intero progetto ad ogni salvataggio, il che potrebbe causare un rallentamento significativo dell'editor."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Scan directory invalid. Pick an existing directory."
msgstr "Directory non valida. Scegli una directory esistente."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "No scan directory, resources auto-discovery is disabled."
msgstr "Nessuna directory definita, il rilevamento automatico è disabilitato."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid ""
"File extension restrictions are optional. Separate multiple extensions with "
"commas."
msgstr ""
"Le restrizioni sulle estensioni file sono opzionali. Separa più estensioni "
"con virgole."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid ""
"File extension filter active. Scan will be limited to matching extensions."
msgstr ""
"Filtro estensioni attivo. La scansione sarà limitata alle estensioni "
"corrispondenti."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Empty file extension detected. Remove extra commas."
msgstr "Rilevata estensione file vuota. Rimuovi le virgole superflue."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Invalid file extension detected. Remove disallowed characters."
msgstr "Estensione file non valida. Rimuovi i caratteri non consentiti."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Include filter active. Only matching paths will be scanned."
msgstr ""
"Filtro di inclusione attivo. Verranno analizzati solo i percorsi "
"corrispondenti."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Invalid include regex pattern."
msgstr "Espressione regolare di inclusione non valida."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Exclude filter active. Matching paths will be skipped."
msgstr ""
"Filtro di esclusione attivo. I percorsi corrispondenti verranno ignorati."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Invalid exclude regex pattern."
msgstr "Espressione regolare di esclusione non valida."

