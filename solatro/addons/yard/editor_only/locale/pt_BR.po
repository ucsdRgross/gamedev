#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Class/script is a Resource subclass."
msgstr "A classe/script é uma subclasse de Resource."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid ""
"Invalid class/script. Expected a Resource subclass (built-in, class_name, or "
"[u]quoted[/u] script path)."
msgstr ""
"Classe/script inválido. Era esperada uma subclasse de Resource (integrada, "
"class_name, ou caminho de script [u]entre aspas[/u])."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "No class filter, all Resource files will be accepted to the registry."
msgstr ""
"Sem filtro de classe, todos os arquivos Resource serão aceitos no registro."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Scan directory valid. Will watch for new Resources…"
msgstr "Diretório válido. Novos recursos serão detectados automaticamente…"

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Scan directory is set to the project root ([code]res://[/code]). This will scan the entire project on every file save, which may cause significant editor lag."
msgstr "O diretório de análise está definido como a raiz do projeto ([code]res://[/code]). Isso irá analisar o projeto inteiro a cada salvamento de arquivo, o que pode causar lentidão significativa no editor."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Scan directory invalid. Pick an existing directory."
msgstr "Diretório inválido. Escolha um diretório existente."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "No scan directory, resources auto-discovery is disabled."
msgstr "Sem diretório definido, a detecção automática está desativada."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid ""
"File extension restrictions are optional. Separate multiple extensions with "
"commas."
msgstr ""
"Restrições de extensão de arquivo são opcionais. Separe várias extensões com "
"vírgulas."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid ""
"File extension filter active. Scan will be limited to matching extensions."
msgstr ""
"Filtro de extensões ativo. A análise será limitada às extensões "
"correspondentes."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Empty file extension detected. Remove extra commas."
msgstr "Extensão de arquivo vazia detectada. Remova as vírgulas extras."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Invalid file extension detected. Remove disallowed characters."
msgstr ""
"Extensão de arquivo inválida detectada. Remova os caracteres não permitidos."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Include filter active. Only matching paths will be scanned."
msgstr ""
"Filtro de inclusão ativo. Somente caminhos correspondentes serão analisados."

#: addons/yard/editor_only/ui_scenes/components/new_registry_dialog.gd
msgid "Invalid include regex pattern."
msgstr "Expressão regular de inclusão inválida."

