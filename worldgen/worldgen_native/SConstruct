#!/usr/bin/env python
# Build: scons platform=windows target=template_debug custom_api_file=api/extension_api.json
# (see BUILD.md; the api/ dump pins godot-cpp master to the Godot 4.7 stable API)
import os

env = SConscript("godot-cpp/SConstruct")

env.Append(CPPPATH=["src/"])

# The deterministic-terrain twins (terrain_*) promise identical output on every
# machine running this dll. That holds only if the compiler never contracts or
# reorders FP math, so pin the model instead of relying on the toolchain default
# (/O2 alone does NOT imply /fp:fast today -- but a toolchain or flag change
# could silently break every shipped seed).
if env.get("is_msvc", False):
    env.Append(CCFLAGS=["/fp:precise"])
else:
    env.Append(CCFLAGS=["-ffp-contract=off"])

sources = Glob("src/*.cpp")

library = env.SharedLibrary(
    "../addons/worldgen/bin/worldgen_native{}{}".format(env["suffix"], env["SHLIBSUFFIX"]),
    source=sources,
)
Default(library)
